Content-Type: application/json

{
  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1MUBlbWFpbC5vcmciLCJleHAiOjE3NTUyNTc2MDJ9.JFqW51Qz-0Y_Z5Hcp5BW5fgK2bW0d6bhUKG_jrSdLt0",
  "passwd": "1"
