{
  "name": "api-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "seed-n": "ts-node --esm -r tsconfig-paths/register -P tsconfig.json src/Scripts/Migrations/seed_db.ts",
    "dev-x": "ts-node --esm src/main.ts",
    "dev-w": "node --loader ts-node/esm src/main.ts",
    "dev-e": "node --import ts-node/register/esm src/main.ts",
    "dev": "tsx src/main.ts",
    "seed": "tsx src/Scripts/Migrations/seed_db.ts",
    "seed:debug": "node --inspect-brk ./node_modules/.bin/ts-node src/Scripts/Migrations/seed_db.ts",
    "dev-l": "node --loader ts-node/esm src/main.ts",
    "dev-20": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "check": "tsc  --noEmit",
    "watch": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:unit": "jest --config jest.config.cjs tests/unit",
    "test:integration": "jest --config jest.config.cjs tests/integration",
    "test:file": "jest --config jest.config.cjs",
    "test:pattern": "jest --config jest.config.cjs -t",
    "test:live": "jest --config jest.config.live.cjs",
    "test:live:auth": "jest --config jest.config.live.cjs tests/integration/api/auth/",
    "test:live:token": "jest --config jest.config.live.cjs tests/integration/api/auth/auth-token-live.test.ts",
    "test:live:users": "jest --config jest.config.live.cjs tests/integration/api/users/",
    "test:live:watch": "jest --config jest.config.live.cjs --watch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.2",
    "oidc-client": "^1.10.1",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^6.0.1",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "imports": {
    "#Api/*": "./src/01-Api/*",
    "#Contracts/*": "./src/01-Contracts/*",
    "#Application/*": "./src/02-Application/*",
    "#Domain/*": "./src/03-Domain/*",
    "#Infrastructure/*": "./src/04-Infrastructure/*"
  }  
}
