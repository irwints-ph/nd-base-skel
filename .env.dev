# =================================
# Db Configuration .env.dev
# =================================
DB_TYPE=postgres
DB_NAME=sample-app-mdl
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=123
DB_SCHEMA=public
DB_SHOW_SQL=false

AS_AUDIT_ENABLED=true

# Sequelize Pool Settings
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=10000
DB_POOL_EVICT=10000

# Script mode pool overrides
DB_POOL_MAX_SCRIPT=3
DB_POOL_MIN_SCRIPT=0
DB_POOL_IDLE_SCRIPT=500
DB_POOL_ACQUIRE_SCRIPT=30000
DB_POOL_EVICT_SCRIPT=500