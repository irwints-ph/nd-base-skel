{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Express",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.ts",
      "runtimeArgs": ["--nolazy", "--inspect=9229"],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Seed DB",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect-brk",
        "--loader",
        "ts-node/esm"
      ],
      "args": [
        "src/Scripts/Migrations/seed_db.ts",
        "--create-db"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "skipFiles": ["<node_internals>/**"]
    },
    
  ]
}
