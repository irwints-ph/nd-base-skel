# OL_SUBDOMAIN=abs-cbn
# OL_CLIENT_ID=c3e39bb0-19cc-013e-4edd-6b436f52e1fa192696

## Password Policy
PP_ACTIVE=False
PP_MINIMUMLENGTH=12
PP_MINUPPERCASE=2
PP_MINLOWERCASE=2
PP_MINDIGITS=2
PP_MINSPECIALCHARACTERS=3
PP_SPECIALCHARACTERS="!@#$%^&*()_+-=[]{}|;:,.<>?"

## Crypto Config
CC_CLIENT_ID=do-we-have-to-client-id
CC_CLIENT_SECRET=bv5f6QA6FZ5Xz{wgmiZE]vgn7VzFOsftHKVVTJv[CmekW51/ZBgiy{hI

# =================================
# JWT Configuration
# =================================
JWT_TIME_OUT=1440
JWT_SECRET_KEY=super-super-duper-over-duper-secret
JWT_ALGORITHMS=HS256
JWT_ISSUER=MyApiIssuer

# =================================
# Google OIDC
# =================================
GOOGLE_CLIENT_ID=X

# =================================
# Email Configuration
# =================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=x
SMTP_PASS=x

# =================================
# OTP Configuration
# =================================
OTP_SECRET_KEY=super-super-duper-over-duper-secret
OTP_EXPIRE_SEC=300

# =================================
# AdminSettings
# =================================
AS_SUPER_ROOT=1
AS_ADMIN_EMAIL=
AS_COMPANY_NAME=ABS-CBN
AS_EMAIL_PROVIDER=Console
AS_AUDIT_ENABLED=true