## .env
APIVERSION=1.4
PORT=3000
# ENVIRONMENT=dek

# =================================
# Db Configuration
# =================================
DB_TYPE=sqlite
DB_NAME=node-app.sqlite3
DB_SHOW_SQL=false
# APP_ENV=dev
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=appdb
# DB_USER=appuser
# DB_PASSWORD=secret

# =================================
# For CORS
# =================================
# Note: Need the ending / to work
BACKEND_CORS_ORIGINS=http://localhost:8500/,http://localhost:5601, http://192.168.100.114:8500, http://localhost:8650, http://localhost:8600,http://192.168.1.10:8500

# =================================
# OIDC authentication
# =================================
OL_SUBDOMAIN=abs-cbn-dev
OL_CLIENT_ID=e8e97e20-55fd-013c-1047-0a56945aa1c4232798

OL_AUTO_CREATE=False
# OL_CLIENT_SECRET=
